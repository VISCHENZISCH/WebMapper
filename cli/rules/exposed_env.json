{
  "name": "exposed_env_file",
  "type": "EXPOSED_ENV_FILE",
  "severity": "critical",
  "detail": "Fichier d'environnement (.env) accessible publiquement à l'adresse : {url}. Ce fichier contient généralement des mots de passe de base de données, des clés d'API et des secrets sensibles.",
  "requests": [
    {
      "method": "GET",
      "path": "/.env",
      "matchers": [
        {
          "type": "status",
          "status": 200
        },
        {
          "type": "regex",
          "part": "body",
          "condition": "or",
          "regex": [
            "^DB_(HOST|PASSWORD|USER|DATABASE)=",
            "^AWS_(SECRET|ACCESS)=",
            "^APP_(ENV|SECRET|KEY)="
          ]
        }
      ]
    }
  ]
}
