{
  "name": "exposed_htpasswd",
  "type": "EXPOSED_HTPASSWD",
  "severity": "high",
  "detail": "Fichier de mots de passe htpasswd exposé à l'adresse : {url}. Les attaquants peuvent casser les hash pour obtenir les accès.",
  "requests": [
    {
      "method": "GET",
      "path": "/.htpasswd",
      "matchers": [
        {
          "type": "status",
          "status": 200
        },
        {
          "type": "regex",
          "part": "body",
          "condition": "or",
          "regex": [
            "^[a-zA-Z0-9_-]+:\\$apr1\\$",
            "^[a-zA-Z0-9_-]+:\\{SHA\\}"
          ]
        }
      ]
    }
  ]
}
